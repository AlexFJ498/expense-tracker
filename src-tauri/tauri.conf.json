{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Expense Tracker",
  "version": "1.4.13",
  "identifier": "com.alejandrofuerte.expense-tracker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Expense Tracker",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' asset: http://asset.localhost; connect-src ipc: http://ipc.localhost https://github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFODg4M0U1NDI5QTA4MzQKUldRMENKcEM1WU9JWHFYWnU0VCt2ZGlJVEo3MURyWWNROStOanBWeTEvRXlxSXNwa1NqVnVKanMK",
      "endpoints": [
        "https://github.com/AlexFJ498/expense-tracker/releases/latest/download/latest.json"
      ]
    }
  }
}
